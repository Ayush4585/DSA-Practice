class Solution {
    public int maximumLength(int[] nums) {
        Map<Long, Integer> frequency = new HashMap<>();
        for (int num : nums) {
            frequency.merge((long) num, 1, Integer::sum);
        }

        int result = 0;
        int ones = frequency.getOrDefault(1L, 0);
        result = (ones % 2 == 1) ? ones : ones - 1;

        for (long num : frequency.keySet()) {
            if (num == 1) continue;

            long curr = num;
            int len = 0;
            while (frequency.getOrDefault(curr, 0) > 1) {
                len += 2;
                curr = curr * curr;
            }
            len += frequency.containsKey(curr) ? 1 : -1;

            result = Math.max(result, len);
        }

        return result;
    }
}
