class Solution {
    int[][][] dp;

    public int solve(int i, int j, int[][] grid, int k) {
        int n = grid.length;
        int m = grid[0].length;

        if (k < 0 || i >= n || j >= m) return Integer.MIN_VALUE;

        if (i == n - 1 && j == m - 1) {
            int newK = k - (grid[i][j] == 0 ? 0 : 1);
            if (newK >= 0) return grid[i][j];
            return Integer.MIN_VALUE;
        }

        if (dp[i][j][k] != -1) return dp[i][j][k];

        int newK = k - (grid[i][j] == 0 ? 0 : 1);
        int right = solve(i, j + 1, grid, newK);
        int down  = solve(i + 1, j, grid, newK);

        int best = Math.max(right, down);
        if (best == Integer.MIN_VALUE) return dp[i][j][k] = Integer.MIN_VALUE;

        return dp[i][j][k] = grid[i][j] + best;
    }

    public int maxPathScore(int[][] grid, int k) {
        int n = grid.length;
        int m = grid[0].length;

        dp = new int[n][m][k + 1];
        for (int[][] a : dp)
            for (int[] b : a)
                Arrays.fill(b, -1);

        int ans = solve(0, 0, grid, k);
        return ans == Integer.MIN_VALUE ? -1 : ans;
    }
}
