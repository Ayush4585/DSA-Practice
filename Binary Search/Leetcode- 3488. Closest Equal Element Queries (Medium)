class Solution {
    public List<Integer> solveQueries(int[] nums, int[] queries) {
        int n = nums.length;

        Map<Integer, List<Integer>> store = new HashMap<>();

        for (int i = 0; i < n; i++) {
            store.computeIfAbsent(nums[i], k -> new ArrayList<>()).add(i);
        }

        List<Integer> ans = new ArrayList<>();

        for (int q : queries) {
            int val = nums[q];
            List<Integer> list = store.get(val);

            if (list.size() == 1) {
                ans.add(-1);
                continue;
            }

            int pos = Collections.binarySearch(list, q);

            int prevIndex = (pos - 1 + list.size()) % list.size();
            int nextIndex = (pos + 1) % list.size();

            int prev = list.get(prevIndex);
            int next = list.get(nextIndex);

            int distPrev = Math.abs(q - prev);
            int distNext = Math.abs(q - next);

            int minDist = Math.min(
                Math.min(distPrev, n - distPrev),
                Math.min(distNext, n - distNext)
            );

            ans.add(minDist);
        }

        return ans;
    }
}
