class Solution {
    public int numberOfSubstrings(String s) {
        int ans = 0, n = s.length();
        int left = 0;
        int[] count = new int[3];
        char[] arr = s.toCharArray();
        for (int right = 0; right < n; right++) {
            count[arr[right] - 'a']++;
            while (count[0] > 0 && count[1] > 0 && count[2] > 0) {
                ans += (n - right);
                count[arr[left] - 'a']--;
                left++;
            }
        }
        return ans;
    }
}
