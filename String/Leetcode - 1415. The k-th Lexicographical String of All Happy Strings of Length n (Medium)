class Solution {
public:
    string getHappyString(int n, int k) {
        int total = 3 * pow(2, n - 1);
        if (k > total) return "";

        vector<char> values = {'a','b','c'};
        string ans = "";

        int len = pow(2, n - 1);

        for(int i = 0; i < n; i++) {
            int ind = (k - 1) / len;

            for(char c : values) {
                if(ans.empty() || ans.back() != c) {
                    if(ind == 0) {
                        ans += c;
                        break;
                    }
                    ind--;
                }
            }

            k = (k - 1) % len + 1;
            len /= 2;
        }

        return ans;
    }
};
