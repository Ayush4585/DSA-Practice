class Robot {

    int[][] directions = {
        {1, 0},   // East
        {0, 1},   // North
        {-1, 0},  // West
        {0, -1}   // South
    };

    int maxX, maxY;
    int x = 0, y = 0;
    int currDir = 0;
    int totalPerimeter;

   public Robot(int width, int height) {
    maxX = width - 1;
    maxY = height - 1;
    totalPerimeter = 2 * (width - 1) + 2 * (height - 1); // must be EXACTLY this
     System.out.println("totalPerimeter = " + totalPerimeter);
}

public void step(int num) {
    num %= totalPerimeter;

    if (num == 0) {
        num = totalPerimeter;
    }

    while (num > 0) {
        int nx = x + (directions[currDir][0] * num);
        int ny = y + (directions[currDir][1] * num);

        if (nx > maxX || ny > maxY || nx < 0 || ny < 0) {
            if (currDir == 0) {           
                num -= (maxX - x);
                x = maxX;
            } else if (currDir == 1) {    
                num -= (maxY - y);
                y = maxY;
            } else if (currDir == 2) {    
                num -= x;
                x = 0;
            } else {                      
                num -= y;
                y = 0;
            }
            currDir = (currDir + 1) % 4;
        } else {
            x = nx;
            y = ny;
            num = 0;
        }
    }
}

    public int[] getPos() {
        return new int[]{x, y};
    }

    public String getDir() {
        return switch (currDir) {
            case 0 -> "East";
            case 1 -> "North";
            case 2 -> "West";
            case 3 -> "South";
            default -> "";
        };
    }
}
