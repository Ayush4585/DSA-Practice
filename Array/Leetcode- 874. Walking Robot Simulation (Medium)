import java.util.*;

class Solution {
    public int robotSim(int[] commands, int[][] obstacles) {
        Set<String> blocked = new HashSet<>();
        for (int[] o : obstacles) {
            blocked.add(o[0] + "," + o[1]);
        }
        int[][] directions = {
            {0, 1}, {1, 0}, {0, -1}, {-1, 0}
        };
        int x = 0, y = 0;
        int currDir = 0; 
        int maxDist = 0;

        for (int ele : commands) {
            if (ele == -1) {
                currDir = (currDir + 1) % 4;
            } 
            else if (ele == -2) {
                currDir = (currDir + 3) % 4; 
            } 
            else {
                while (ele-- > 0) {
                    int newX = x + directions[currDir][0];
                    int newY = y + directions[currDir][1];
                    if (blocked.contains(newX + "," + newY)) break;

                    x = newX;
                    y = newY;

                    maxDist = Math.max(maxDist, x * x + y * y);
                }
            }
        }

        return maxDist;
    }
}
