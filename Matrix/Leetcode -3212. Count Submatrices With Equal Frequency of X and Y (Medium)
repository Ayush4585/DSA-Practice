class Solution {
    public int numberOfSubmatrices(char[][] grid) {
        int n = grid.length, m = grid[0].length;
        int[] colSum = new int[m];   
        int[] colX   = new int[m];
        int ans = 0;

        for (int i = 0; i < n; i++) {
            int rowSum = 0, rowX = 0;
            for (int j = 0; j < m; j++) {
                int val = grid[i][j] == 'X' ? 1 : (grid[i][j] == 'Y' ? -1 : 0);
                colSum[j] += val;
                colX[j]   += grid[i][j] == 'X' ? 1 : 0;

                rowSum += colSum[j];   
                rowX   += colX[j];

                if (rowSum == 0 && rowX > 0) ans++;
            }
        }
        return ans;
    }
}
