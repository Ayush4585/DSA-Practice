class Solution {
    public int countSubmatrices(int[][] grid, int k) {
        int ans=0;
        int n=grid.length;
        int m=grid[0].length;
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                if(j>0)
                grid[i][j]+=grid[i][j-1];
            }
        }
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                if(i>0)
                grid[i][j]+=grid[i-1][j];
                if(grid[i][j]<=k)ans++;
            }
        }
        return ans;
    }
}
