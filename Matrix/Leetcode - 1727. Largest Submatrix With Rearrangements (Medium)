class Solution {
public:
    int largestSubmatrix(vector<vector<int>>& mat) {
         int m = mat.size();
        int n = mat[0].size();
        int result = 0;
        
        for(int i = 0; i < m; i++) {
            for(int j = 0; j < n; j++) {
                if(mat[i][j] == 1 && i > 0) {
                    mat[i][j] += mat[i-1][j];
                }
                
            }
            
            
            vector<int> currRow = mat[i];
            sort(begin(currRow), end(currRow), greater<int>());
            for(int j = 0; j < n; j++) {
                int base   = (j+1);
                int height = currRow[j];
                
                result = max(result, base*height);
            }
            
        }
        
        return result;
    }
};
