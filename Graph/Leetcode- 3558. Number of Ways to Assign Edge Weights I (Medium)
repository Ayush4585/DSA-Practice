class Solution {
    static final int MOD = 1_000_000_007;

    public int assignEdgeWeights(int[][] edges) {
        HashMap<Integer, List<Integer>> adj = new HashMap<>();
        int n = edges.length;

        for (int ind = 0; ind < n; ind++) {
            adj.computeIfAbsent(edges[ind][0], k -> new ArrayList<>()).add(edges[ind][1]);
            adj.computeIfAbsent(edges[ind][1], k -> new ArrayList<>()).add(edges[ind][0]);
        }

        int[] vis = new int[n + 2];
        vis[1] = 1;

        Queue<Integer> queue = new LinkedList<>();
        queue.offer(1);
        int height = 0;

        while (!queue.isEmpty()) {
            int size = queue.size();         
            for (int i = 0; i < size; i++) {
                int node = queue.poll();
                List<Integer> neighbors = adj.getOrDefault(node, new ArrayList<>());
                for (int neighbor : neighbors) {
                    if (vis[neighbor] == 0) {
                        vis[neighbor] = 1;
                        queue.offer(neighbor);
                    }
                }
            }
            height++;                        
        }

        height--;                       
        return modPow(2, height - 1);
    }

    private int modPow(long base, long exp) {
        long result = 1;
        base %= MOD;
        while (exp > 0) {
            if ((exp & 1) == 1) result = result * base % MOD;
            base = base * base % MOD;
            exp >>= 1;
        }
        return (int) result;
    }
}
